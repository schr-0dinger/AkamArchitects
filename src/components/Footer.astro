---
import { Image } from "astro:assets";
import { footerLinks } from "../lib/site";
import type { SiteSettings } from "../lib/settings";

interface Props {
  settings: SiteSettings;
}

const { settings } = Astro.props;
const year = new Date().getFullYear();

const socialLinks = [
  { label: "Facebook", href: settings.socialFacebook },
  { label: "Instagram", href: settings.socialInstagram },
  { label: "LinkedIn", href: settings.socialLinkedin },
].filter((link): link is { label: string; href: string } => Boolean(link.href));
---

<footer class="border-t border-hairline bg-paper text-ink">
  <div class="container-page grid gap-12 py-16 md:grid-cols-3 md:py-20">
    <div>
      <Image src={settings.logoFull} alt={settings.logoAlt} height={400} class="h-28 w-auto" />
      <p class="mt-4 max-w-xs text-sm leading-relaxed text-stone">
        {settings.tagline} Architecture and construction for residential, commercial,
        hospitality, and institutional clients across Kerala.
      </p>
    </div>

    <div>
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-stone">Navigate</p>
      <ul class="mt-4 grid grid-cols-2 gap-3 text-sm">
        {
          footerLinks.map((link) => (
            <li>
              <a href={link.href} class="transition-colors hover:text-accent">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-stone">Contact</p>
      <ul class="mt-4 space-y-2 text-sm">
        <li>
          <a href={settings.phoneHref} class="transition-colors hover:text-accent">
            {settings.phone}
          </a>
        </li>
        <li>
          <a href={`mailto:${settings.email}`} class="transition-colors hover:text-accent">
            {settings.email}
          </a>
        </li>
        <li class="pt-1 text-stone">
          {settings.addressLine1}{settings.addressLine2 && `, ${settings.addressLine2}`}<br />
          {settings.addressCity}, {settings.addressState} {settings.addressPostalCode}
        </li>
      </ul>
      {
        socialLinks.length > 0 && (
          <ul class="mt-5 flex gap-4 text-xs uppercase tracking-[0.15em]">
            {socialLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="transition-colors hover:text-accent"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </div>

  <div class="border-t border-hairline">
    <div class="container-page flex flex-col gap-2 py-6 text-xs text-stone md:flex-row md:items-center md:justify-between">
      <p>&copy; {year} {settings.name}. All rights reserved.</p>
      <p>Designed &amp; built with Astro.</p>
    </div>
  </div>
</footer>
