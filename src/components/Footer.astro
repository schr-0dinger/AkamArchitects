---
import { Image } from "astro:assets";
import { footerLinks } from "../lib/site";
import type { SiteSettings } from "../lib/settings";

interface Props {
  settings: SiteSettings;
}

const { settings } = Astro.props;
const year = new Date().getFullYear();

const socialLinks = [
  { label: "Facebook", href: settings.socialFacebook, icon: "facebook" as const },
  { label: "Instagram", href: settings.socialInstagram, icon: "instagram" as const },
  { label: "LinkedIn", href: settings.socialLinkedin, icon: "linkedin" as const },
].filter(
  (link): link is { label: string; href: string; icon: typeof link.icon } => Boolean(link.href),
);
---

<footer class="border-t border-hairline bg-paper text-ink">
  <div class="container-page grid gap-12 py-16 md:grid-cols-2 md:py-20 lg:grid-cols-4">
    <div>
      <Image src={settings.logoFull} alt={settings.logoAlt} height={340} format="avif" class="h-28 w-auto" />
      <p class="mt-4 max-w-xs text-sm leading-relaxed text-stone">
        {settings.tagline} Architecture and construction for residential, commercial,
        hospitality, and institutional clients across Kerala.
      </p>
      {
        socialLinks.length > 0 && (
          <ul class="mt-5 flex gap-3">
            {socialLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={link.label}
                  class="flex h-9 w-9 items-center justify-center rounded-full border border-hairline text-ink transition-colors hover:border-accent hover:text-accent"
                >
                  {link.icon === "facebook" && (
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <path
                        d="M14 9h3V5.5h-3c-2.21 0-4 1.79-4 4V12H7v3.5h3V22h3.5v-6.5H16l1-3.5h-3.5v-2c0-.55.45-1 1-1z"
                        fill="currentColor"
                      />
                    </svg>
                  )}
                  {link.icon === "instagram" && (
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <rect x="3.5" y="3.5" width="17" height="17" rx="4.5" stroke="currentColor" stroke-width="1.5" />
                      <circle cx="12" cy="12" r="4.2" stroke="currentColor" stroke-width="1.5" />
                      <circle cx="17" cy="7" r="1.1" fill="currentColor" />
                    </svg>
                  )}
                  {link.icon === "linkedin" && (
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                      <rect x="3.5" y="3.5" width="17" height="17" rx="2.5" stroke="currentColor" stroke-width="1.5" />
                      <circle cx="8" cy="8.5" r="1.2" fill="currentColor" />
                      <path d="M8 11.5v6M12.5 11.5v6M12.5 14.2c0-1.5 1-2.7 2.5-2.7s2 1.2 2 2.7v3.3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                  )}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>

    <div>
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-stone">Navigate</p>
      <ul class="mt-2 grid grid-cols-2 text-sm">
        {
          footerLinks.map((link) => (
            <li>
              <a href={link.href} class="inline-block py-2 transition-colors hover:text-accent">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-stone">Contact</p>
      <ul class="mt-2 text-sm">
        {
          settings.phones.map((phone) => (
            <li>
              <a href={phone.href} class="inline-block py-1.5 transition-colors hover:text-accent">
                {phone.number}
              </a>
            </li>
          ))
        }
        <li>
          <a href={`mailto:${settings.email}`} class="inline-block py-1.5 transition-colors hover:text-accent">
            {settings.email}
          </a>
        </li>
      </ul>
    </div>

    <div>
      <p class="text-xs font-medium uppercase tracking-[0.2em] text-stone">Locations</p>
      <ul class="mt-2 space-y-4 text-sm">
        {
          settings.addresses.map((address) => (
            <li class="text-stone">
              {address.label && (
                <span class="block text-xs uppercase tracking-[0.15em] text-stone">
                  {address.label}
                </span>
              )}
              <span class="mt-1 block">
                {address.line1}
                {address.line2 && (
                  <>
                    <br />
                    {address.line2}
                  </>
                )}
                <br />
                {address.city}, {address.state} {address.postalCode}
              </span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="border-t border-hairline">
    <div class="container-page flex flex-col gap-2 py-6 text-xs text-stone md:flex-row md:items-center md:justify-between">
      <p>&copy; {year} {settings.name}. All rights reserved.</p>
      <p>Designed &amp; built with Astro.</p>
    </div>
  </div>
</footer>
