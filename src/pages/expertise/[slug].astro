---
import { getCollection, type CollectionEntry, render } from "astro:content";
import { Image, getImage } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import Reveal from "../../components/Reveal.tsx";
import Lightbox from "../../components/Lightbox.tsx";
import { withBase } from "../../lib/urls";

export async function getStaticPaths() {
  const expertise = await getCollection("expertise");
  return expertise.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"expertise">;
}

const { entry } = Astro.props as Props;
const { title, description, detailIntro, image, imageAlt, gallery } = entry.data;
const { Content } = await render(entry);

const galleryImages = await Promise.all(
  gallery.map(async (item) => {
    const optimized = await getImage({ src: item.image, width: 1400, format: "avif", quality: 53 });
    return {
      src: optimized.src,
      alt: item.alt,
      width: optimized.attributes.width as number,
      height: optimized.attributes.height as number,
    };
  }),
);
---

<Layout title={title} description={description}>
  <section class="container-page pb-14 pt-36 md:pt-44">
    <Reveal client:visible>
      <a
        href={withBase("/expertise")}
        class="text-sm tracking-wide underline underline-offset-4 hover:text-accent"
      >
        Back to Expertise
      </a>
      <p class="mt-8 text-xs uppercase tracking-[0.3em] text-accent">Expertise</p>
      <h1 class="mt-3 max-w-3xl text-balance font-heading text-4xl tracking-tight md:text-6xl">
        {title}
      </h1>
      <p class="mt-6 max-w-2xl text-balance text-lg leading-relaxed text-stone">
        {detailIntro}
      </p>
    </Reveal>
  </section>

  <section class="container-page grid gap-10 pb-20 pt-6 md:grid-cols-[0.8fr_1.4fr] md:pb-28">
    <Reveal client:visible>
      <div class="border-t border-hairline pt-6">
        <div class="aspect-[4/3] overflow-hidden bg-mist">
          <Image
            src={image}
            alt={imageAlt}
            widths={[400, 600, 800]}
            sizes="(min-width: 768px) 30vw, 100vw"
            format="avif"
            quality={50}
            loading="eager"
            class="h-full w-full object-cover grayscale"
          />
        </div>
        <p class="mt-6 text-xs uppercase tracking-[0.2em] text-stone">How We Help</p>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-stone">{description}</p>
      </div>
    </Reveal>
    <Reveal client:visible delay={0.1}>
      <div class="prose-service max-w-2xl leading-relaxed text-stone">
        <Content />
      </div>
    </Reveal>
  </section>

  {
    galleryImages.length > 0 && (
      <section class="container-page pb-20 md:pb-28">
        <Reveal client:visible>
          <h2 class="border-t border-hairline pt-6 font-heading text-2xl tracking-tight">
            Gallery
          </h2>
        </Reveal>
        <div class="mt-8">
          <Lightbox client:visible images={galleryImages} />
        </div>
      </section>
    )
  }

  <section class="border-t border-hairline bg-accent py-16 md:py-20">
    <div class="container-page flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
      <h2 class="max-w-xl text-balance font-heading text-3xl tracking-tight text-ink md:text-4xl">
        Need this service for an upcoming project?
      </h2>
      <a
        href={withBase("/contact")}
        class="shrink-0 rounded-full bg-ink px-8 py-4 text-sm font-medium tracking-wide text-paper transition-transform hover:scale-[1.03]"
      >
        Start a Conversation
      </a>
    </div>
  </section>
</Layout>

<style>
  .prose-service :global(h2) {
    margin-top: 2.5rem;
    font-family: var(--font-heading);
    font-size: 1.5rem;
    line-height: 1.2;
    color: var(--color-ink);
  }
  .prose-service :global(h2:first-child) {
    margin-top: 0;
  }
  .prose-service :global(p) {
    margin-top: 0.9rem;
  }
  .prose-service :global(ul) {
    margin-top: 1rem;
    list-style: disc;
    padding-left: 1.25rem;
  }
  .prose-service :global(li) {
    margin-top: 0.5rem;
  }
</style>
