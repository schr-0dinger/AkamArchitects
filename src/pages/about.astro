---
import { Image } from "astro:assets";
import { getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Reveal from "../components/Reveal.tsx";
import AnimatedCounter from "../components/AnimatedCounter.tsx";
import { getSiteSettings } from "../lib/settings";
import { withBase } from "../lib/urls";

const about = await getEntry("about", "about");
if (!about) throw new Error("Missing content entry: src/content/about/about.md");
const {
  eyebrow,
  heading,
  heroImage,
  heroImageAlt,
  storyEyebrow,
  storyHeading,
  storyBody,
  vision,
  mission,
  timeline,
  stats,
} = about.data;

const storyParagraphs = (storyBody ?? "")
  .trim()
  .split(/\n\s*\n/)
  .map((p) => p.trim())
  .filter(Boolean);

const settings = await getSiteSettings();
const yearsInPractice = new Date().getFullYear() - settings.founded;
---

<Layout
  title="About"
  description="The story, philosophy, and people behind AKAM Architects & Construction."
  transparentNav
>
  <section class="relative flex h-[70svh] min-h-[480px] items-end overflow-hidden bg-ink">
    <Image
      src={heroImage}
      alt={heroImageAlt}
      class="absolute inset-0 h-full w-full object-cover"
      widths={[800, 1200, 1800]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-ink/90 via-ink/20 to-ink/40"></div>
    <div class="container-page relative z-10 pb-16 pt-40 text-paper">
      {
        eyebrow && (
          <p class="hero-fade text-xs uppercase tracking-[0.3em] text-accent">{eyebrow}</p>
        )
      }
      <h1 class="hero-fade mt-4 max-w-2xl text-balance font-heading text-4xl font-semibold tracking-tight md:text-6xl" style="animation-delay:0.1s">
        {heading}
      </h1>
    </div>
  </section>

  <!-- Story -->
  {
    (storyHeading || storyParagraphs.length > 0) && (
      <section class="container-page grid gap-12 py-16 md:grid-cols-2 md:py-20">
        <Reveal client:visible>
          {storyEyebrow && (
            <p class="text-xs uppercase tracking-[0.3em] text-accent">{storyEyebrow}</p>
          )}
          {storyHeading && (
            <h2 class="mt-3 text-balance font-heading text-3xl tracking-tight md:text-4xl">
              {storyHeading}
            </h2>
          )}
        </Reveal>
        <Reveal client:visible delay={0.1} className="space-y-5 leading-relaxed text-stone">
          {storyParagraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </Reveal>
      </section>
    )
  }

  <!-- Vision / Mission -->
  {
    (vision || mission) && (
      <section class="border-y border-hairline bg-mist py-16 md:py-20">
        <div class="container-page grid gap-12 md:grid-cols-2">
          {vision && (
            <Reveal client:visible>
              <h2 class="font-heading text-2xl tracking-tight">Vision</h2>
              <p class="mt-4 max-w-md leading-relaxed text-stone">{vision}</p>
            </Reveal>
          )}
          {mission && (
            <Reveal client:visible delay={0.08}>
              <h2 class="font-heading text-2xl tracking-tight">Mission</h2>
              <p class="mt-4 max-w-md leading-relaxed text-stone">{mission}</p>
            </Reveal>
          )}
        </div>
      </section>
    )
  }

  <!-- Stats -->
  <section class="container-page py-16 md:py-20">
    <div class="grid grid-cols-2 gap-10 md:grid-cols-4">
      <Reveal client:visible className="text-center md:text-left">
        <p class="font-heading text-4xl tracking-tight text-ink md:text-5xl">
          <AnimatedCounter client:visible value={yearsInPractice} suffix="+" />
        </p>
        <p class="mt-2 text-sm uppercase tracking-[0.15em] text-stone">Years in practice</p>
      </Reveal>
      {
        stats.map((stat, index) => (
          <Reveal client:visible delay={(index + 1) * 0.06} className="text-center md:text-left">
            <p class="font-heading text-4xl tracking-tight text-ink md:text-5xl">
              <AnimatedCounter client:visible value={stat.value} suffix={stat.suffix} />
            </p>
            <p class="mt-2 text-sm uppercase tracking-[0.15em] text-stone">{stat.label}</p>
          </Reveal>
        ))
      }
    </div>
  </section>

  <!-- Timeline -->
  {
    timeline.length > 0 && (
      <section class="border-t border-hairline bg-ink py-16 text-paper md:py-20">
        <div class="container-page">
          <Reveal client:visible>
            <p class="text-xs uppercase tracking-[0.3em] text-accent">Milestones</p>
            <h2 class="mt-3 max-w-xl text-balance font-heading text-3xl tracking-tight md:text-4xl">
              A brief timeline.
            </h2>
          </Reveal>

          <ol class="mt-14 grid gap-10 border-t border-paper/15 pt-10 md:grid-cols-4 md:gap-6">
            {timeline.map((item, index) => (
              <li>
                <Reveal client:visible delay={index * 0.06}>
                  <p class="font-heading text-lg text-accent">{item.year}</p>
                  <p class="mt-2 font-heading text-lg">{item.title}</p>
                  <p class="mt-2 text-sm leading-relaxed text-paper/70">{item.body}</p>
                </Reveal>
              </li>
            ))}
          </ol>
        </div>
      </section>
    )
  }

  <!-- CTA -->
  <section class="bg-accent py-16 md:py-20">
    <div class="container-page flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
      <h2 class="max-w-xl text-balance font-heading text-3xl tracking-tight text-ink md:text-4xl">
        Curious how we'd approach your site?
      </h2>
      <a
        href={withBase("/contact")}
        class="shrink-0 rounded-full bg-ink px-8 py-4 text-sm font-medium tracking-wide text-paper transition-transform hover:scale-[1.03]"
      >
        Start a Conversation
      </a>
    </div>
  </section>
</Layout>
