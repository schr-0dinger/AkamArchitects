---
import { getCollection, getEntry } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import FeaturedProjectCard from "../components/FeaturedProjectCard.astro";
import TestimonialCard from "../components/TestimonialCard.astro";
import Reveal from "../components/Reveal.tsx";
import { withBase } from "../lib/urls";

const home = await getEntry("home", "home");
if (!home) throw new Error("Missing content entry: src/content/home/home.md");
const {
  heroEyebrow,
  heroHeading,
  heroSubheading,
  heroImage,
  heroImageAlt,
  heroCtaPrimaryLabel,
  heroCtaPrimaryHref,
  heroCtaSecondaryLabel,
  heroCtaSecondaryHref,
  featuredEyebrow,
  featuredHeading,
  expertiseEyebrow,
  expertiseHeading,
  aboutEyebrow,
  aboutHeading,
  aboutBody,
  aboutImage,
  aboutImageAlt,
  testimonialsEyebrow,
  testimonialsHeading,
  ctaHeading,
  ctaButtonLabel,
} = home.data;

const allProjects = await getCollection("projects");
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.featuredOrder - b.data.featuredOrder)
  .slice(0, 6);

const expertise = (await getCollection("expertise")).sort((a, b) => a.data.order - b.data.order);
const testimonials = (await getCollection("testimonials"))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 2);

// A section renders only when it has something to show: an empty collection
// (or an emptied-out key) removes the element - or the whole section - cleanly.
const showHeroCtas = Boolean(
  (heroCtaPrimaryLabel && heroCtaPrimaryHref) || (heroCtaSecondaryLabel && heroCtaSecondaryHref),
);
const showFeatured = featured.length > 0;
const showExpertise = expertise.length > 0;
const showAbout = Boolean(aboutHeading || aboutBody);
const showTestimonials = testimonials.length > 0;
const showCta = Boolean(ctaHeading);
---

<Layout title="Home" transparentNav>
  <!-- Hero -->
  <section class="relative flex h-[100svh] min-h-[600px] items-end overflow-hidden bg-ink">
    <Image
      src={heroImage}
      alt={heroImageAlt}
      class="absolute inset-0 h-full w-full object-cover grayscale"
      widths={[800, 1200, 1600]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-ink/90 via-ink/20 to-ink/40"></div>

    <div class="container-page relative z-10 pb-16 pt-40 text-paper md:pb-20">
      {
        heroEyebrow && (
          <p class="hero-fade text-xs uppercase tracking-[0.3em] text-accent">{heroEyebrow}</p>
        )
      }
      <h1 class="hero-fade mt-5 max-w-3xl text-balance font-heading text-5xl font-semibold leading-[1.05] tracking-tight md:text-7xl" style="animation-delay:0.1s">
        {heroHeading}
      </h1>
      {
        heroSubheading && (
          <p class="hero-fade mt-6 max-w-lg text-balance text-base leading-relaxed text-paper/80 md:text-lg" style="animation-delay:0.2s">
            {heroSubheading}
          </p>
        )
      }
      {
        showHeroCtas && (
          <div class="hero-fade mt-9 flex flex-wrap gap-4" style="animation-delay:0.3s">
            {heroCtaPrimaryLabel && heroCtaPrimaryHref && (
              <a
                href={withBase(heroCtaPrimaryHref)}
                class="rounded-full bg-accent px-7 py-3 text-sm font-medium tracking-wide text-ink transition-transform hover:scale-[1.03]"
              >
                {heroCtaPrimaryLabel}
              </a>
            )}
            {heroCtaSecondaryLabel && heroCtaSecondaryHref && (
              <a
                href={withBase(heroCtaSecondaryHref)}
                class="rounded-full border border-paper/40 px-7 py-3 text-sm font-medium tracking-wide text-paper transition-colors hover:border-accent hover:text-accent"
              >
                {heroCtaSecondaryLabel}
              </a>
            )}
          </div>
        )
      }
    </div>
  </section>

  <!-- Featured Projects -->
  {
    showFeatured && (
      <section class="container-page py-16 md:py-20">
        <Reveal client:visible>
          <div class="flex flex-col items-start justify-between gap-4 md:flex-row md:items-end">
            <div>
              {featuredEyebrow && (
                <p class="text-xs uppercase tracking-[0.3em] text-accent">{featuredEyebrow}</p>
              )}
              {featuredHeading && (
                <h2 class="mt-3 text-balance font-heading text-3xl tracking-tight md:text-4xl">
                  {featuredHeading}
                </h2>
              )}
            </div>
            <a href={withBase("/projects")} class="text-sm tracking-wide underline underline-offset-4 hover:text-accent">
              View all projects
            </a>
          </div>
        </Reveal>

        <div class="mt-10 grid gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
          {featured.map((project, index) => (
            <Reveal client:visible delay={Math.min(index % 3, 2) * 0.08}>
              <FeaturedProjectCard project={project} priority={index < 3} />
            </Reveal>
          ))}
        </div>
      </section>
    )
  }

  <!-- Expertise Overview -->
  {
    showExpertise && (
      <section class="bg-mist py-16 md:py-20">
        <div class="container-page">
          <Reveal client:visible>
            {expertiseEyebrow && (
              <p class="text-xs uppercase tracking-[0.3em] text-accent">{expertiseEyebrow}</p>
            )}
            {expertiseHeading && (
              <h2 class="mt-3 max-w-xl text-balance font-heading text-3xl tracking-tight md:text-4xl">
                {expertiseHeading}
              </h2>
            )}
          </Reveal>

          <div class="mt-10 grid gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
            {expertise.map((item, index) => (
              <Reveal client:visible delay={Math.min(index, 3) * 0.06}>
                <div class="border-t border-hairline pt-6">
                  <span class="font-heading text-sm text-accent">
                    {String(index + 1).padStart(2, "0")}
                  </span>
                  <h3 class="mt-3 font-heading text-xl tracking-tight">{item.data.title}</h3>
                  <p class="mt-2 text-sm leading-relaxed text-stone">{item.data.description}</p>
                </div>
              </Reveal>
            ))}
          </div>

          <a
            href={withBase("/expertise")}
            class="mt-10 inline-block text-sm tracking-wide underline underline-offset-4 hover:text-accent"
          >
            Explore all expertise
          </a>
        </div>
      </section>
    )
  }

  <!-- About Preview -->
  {
    showAbout && (
      <section class="container-page grid gap-10 py-16 md:grid-cols-2 md:items-center md:py-20">
        {aboutImage && (
          <Reveal client:visible y={16}>
            <div class="aspect-[4/3] overflow-hidden bg-mist">
              <Image
                src={aboutImage}
                alt={aboutImageAlt ?? ""}
                class="h-full w-full object-cover grayscale"
                widths={[600, 900, 1400]}
                sizes="(min-width: 768px) 50vw, 100vw"
              />
            </div>
          </Reveal>
        )}
        <Reveal client:visible delay={0.1}>
          {aboutEyebrow && (
            <p class="text-xs uppercase tracking-[0.3em] text-accent">{aboutEyebrow}</p>
          )}
          {aboutHeading && (
            <h2 class="mt-3 text-balance font-heading text-3xl tracking-tight md:text-4xl">
              {aboutHeading}
            </h2>
          )}
          {aboutBody && (
            <p class="mt-5 max-w-lg text-balance leading-relaxed text-stone">{aboutBody}</p>
          )}
          <a
            href={withBase("/about")}
            class="mt-7 inline-block text-sm tracking-wide underline underline-offset-4 hover:text-accent"
          >
            Our story
          </a>
        </Reveal>
      </section>
    )
  }

  <!-- Testimonials -->
  {
    showTestimonials && (
      <section class="border-t border-hairline py-16 md:py-20">
        <div class="container-page">
          <Reveal client:visible>
            {testimonialsEyebrow && (
              <p class="text-xs uppercase tracking-[0.3em] text-accent">{testimonialsEyebrow}</p>
            )}
            {testimonialsHeading && (
              <h2 class="mt-3 max-w-xl text-balance font-heading text-3xl tracking-tight md:text-4xl">
                {testimonialsHeading}
              </h2>
            )}
          </Reveal>

          <div class="mt-10 grid gap-8 md:grid-cols-2">
            {testimonials.map((t, index) => (
              <Reveal client:visible delay={index * 0.08}>
                <TestimonialCard quote={t.data.quote} name={t.data.name} role={t.data.role} />
              </Reveal>
            ))}
          </div>

          <a
            href={withBase("/testimonials")}
            class="mt-8 inline-block text-sm tracking-wide underline underline-offset-4 hover:text-accent"
          >
            Read more testimonials
          </a>
        </div>
      </section>
    )
  }

  <!-- Contact CTA -->
  {
    showCta && (
      <section class="border-t border-hairline bg-accent py-16 md:py-20">
        <div class="container-page flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
          <h2 class="max-w-xl text-balance font-heading text-3xl tracking-tight text-ink md:text-4xl">
            {ctaHeading}
          </h2>
          {ctaButtonLabel && (
            <a
              href={withBase("/contact")}
              class="shrink-0 rounded-full bg-ink px-8 py-4 text-sm font-medium tracking-wide text-paper transition-transform hover:scale-[1.03]"
            >
              {ctaButtonLabel}
            </a>
          )}
        </div>
      </section>
    )
  }
</Layout>
