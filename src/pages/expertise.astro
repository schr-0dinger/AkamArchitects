---
import { getCollection, getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Reveal from "../components/Reveal.tsx";
import { withBase } from "../lib/urls";

const page = await getEntry("pages", "expertise");
const { eyebrow, heading, intro } = page?.data ?? {};

const expertise = (await getCollection("expertise")).sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="Expertise"
  description="Architecture, interior design, project management, and construction expertise from AKAM Architects & Construction."
>
  {
    heading && (
      <section class="container-page pb-16 pt-36 md:pt-44">
        <Reveal client:visible>
          {eyebrow && <p class="text-xs uppercase tracking-[0.3em] text-accent">{eyebrow}</p>}
          <h1 class="mt-3 max-w-2xl text-balance font-heading text-4xl tracking-tight md:text-6xl">
            {heading}
          </h1>
          {intro && <p class="mt-5 max-w-lg leading-relaxed text-stone">{intro}</p>}
        </Reveal>
      </section>
    )
  }

  {
    expertise.length > 0 && (
      <section class={`container-page pb-24 ${heading ? "" : "pt-36 md:pt-44"}`}>
        <div class="grid gap-x-8 gap-y-16 md:grid-cols-2">
          {expertise.map((item, index) => (
            <Reveal client:visible delay={Math.min(index, 4) * 0.06}>
              <div class="border-t border-hairline pt-8">
                <span class="flex h-12 w-12 items-center justify-center rounded-full border border-hairline font-heading text-sm text-accent">
                  {String(index + 1).padStart(2, "0")}
                </span>
                <h2 class="mt-5 font-heading text-2xl tracking-tight">
                  <a
                    href={withBase(`/expertise/${item.id}`)}
                    class="transition-colors hover:text-accent"
                  >
                    {item.data.title}
                  </a>
                </h2>
                <p class="mt-3 max-w-md leading-relaxed text-stone">{item.data.description}</p>
              </div>
            </Reveal>
          ))}
        </div>
      </section>
    )
  }

  <section class="border-t border-hairline bg-accent py-20 md:py-28">
    <div class="container-page flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
      <h2 class="max-w-xl text-balance font-heading text-3xl tracking-tight text-ink md:text-4xl">
        Not sure which service you need? Tell us about the project.
      </h2>
      <a
        href={withBase("/contact")}
        class="shrink-0 rounded-full bg-ink px-8 py-4 text-sm font-medium tracking-wide text-paper transition-transform hover:scale-[1.03]"
      >
        Get in Touch
      </a>
    </div>
  </section>
</Layout>
