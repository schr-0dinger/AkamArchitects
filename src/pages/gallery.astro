---
import { getCollection, getEntry } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Reveal from "../components/Reveal.tsx";
import { withBase } from "../lib/urls";

const page = await getEntry("pages", "gallery");
const { eyebrow, heading, intro } = page?.data ?? {};

const allProjects = await getCollection("projects");
const projects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.featuredOrder - b.data.featuredOrder);

const galleryItems = projects.flatMap((project) => {
  const { title, category, location, heroImage, heroImageAlt, gallery } = project.data;
  const images = [{ image: heroImage, alt: heroImageAlt }, ...gallery];
  return images.map((img, index) => ({
    key: `${project.id}-${index}`,
    image: img.image,
    alt: img.alt,
    title,
    category,
    location,
    href: withBase(`/projects/${project.id}`),
  }));
});

// Justified-row layout: every row is the same height (set in CSS below); each
// image's width within its row is proportional to its own aspect ratio, so
// the only variability is width, and every row already sums to exactly 100%.
const ROW_SIZE = 4;
const rows = [];
for (let i = 0; i < galleryItems.length; i += ROW_SIZE) {
  const rowItems = galleryItems.slice(i, i + ROW_SIZE);
  const ratios = rowItems.map((item) => item.image.width / item.image.height);
  const ratioSum = ratios.reduce((sum, ratio) => sum + ratio, 0);
  rows.push(
    rowItems.map((item, i2) => ({ ...item, widthPercent: (ratios[i2] / ratioSum) * 100 })),
  );
}
---

<Layout
  title="Gallery"
  description="A visual index of AKAM Architects & Construction's work - every image links back to its project."
>
  <section class="container-page pb-10 pt-36 md:pt-44">
    {
      heading && (
        <Reveal client:visible>
          {eyebrow && <p class="text-xs uppercase tracking-[0.3em] text-accent">{eyebrow}</p>}
          <h1 class="mt-3 max-w-2xl text-balance font-heading text-4xl tracking-tight md:text-6xl">
            {heading}
          </h1>
          {intro && <p class="mt-5 max-w-lg leading-relaxed text-stone">{intro}</p>}
        </Reveal>
      )
    }
  </section>

  <section class="container-page pb-24">
    <div class="flex flex-col gap-3 sm:gap-4">
      {
        rows.map((row, rowIndex) => (
          <div class="justified-row flex h-64 gap-3 sm:h-72 sm:gap-4 lg:h-80">
            {row.map((item, itemIndex) => {
              const globalIndex = rowIndex * ROW_SIZE + itemIndex;
              return (
                <a
                  href={item.href}
                  class="justified-item group relative block overflow-hidden bg-ink"
                  style={`--w: ${item.widthPercent}%`}
                  aria-label={`${item.title} — ${item.category}, ${item.location}`}
                >
                  <Image
                    src={item.image}
                    alt={item.alt}
                    widths={[400, 700, 1000]}
                    sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                    loading={globalIndex < 6 ? "eager" : "lazy"}
                    class="h-full w-full object-cover"
                  />
                  <div class="pointer-events-none absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-ink/90 via-ink/10 to-transparent p-4 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                    <p class="font-heading text-sm leading-tight text-paper">{item.title}</p>
                    <p class="mt-0.5 text-[0.65rem] uppercase tracking-[0.15em] text-paper/70">
                      {item.category} — {item.location}
                    </p>
                  </div>
                </a>
              );
            })}
          </div>
        ))
      }
    </div>
  </section>
</Layout>

<style>
  /* Justified gallery rows: every row is a fixed, uniform height (set via
     Tailwind h-* classes above) - only image widths vary, driven by each
     image's own aspect ratio via the --w custom property. Widths always sum
     to exactly 100% of the row, so every row stays perfectly contained.
     Hovering one image grows it and shrinks its row-siblings to match,
     without ever overflowing - flex-shrink guarantees the row still sums
     to exactly 100%, it's just no longer split proportionally by --w. */
  .justified-item {
    flex: 0 1 var(--w);
    transition: flex-basis 500ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .justified-row:has(.justified-item:hover) .justified-item:hover {
    flex-basis: calc(var(--w) * 2.4);
    flex-shrink: 0;
  }

  @media (hover: none) {
    .justified-row:has(.justified-item:hover) .justified-item:hover {
      flex-basis: var(--w);
      flex-shrink: 1;
    }
  }
</style>
