---
import { getCollection, getEntry } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Reveal from "../components/Reveal.tsx";
import { withBase } from "../lib/urls";

const page = await getEntry("pages", "gallery");
const { eyebrow, heading, intro } = page?.data ?? {};

const allProjects = await getCollection("projects");
const projects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.featuredOrder - b.data.featuredOrder);

const galleryItems = projects.flatMap((project) => {
  const { title, category, location, heroImage, heroImageAlt, gallery } = project.data;
  const images = [{ image: heroImage, alt: heroImageAlt }, ...gallery];
  return images.map((img, index) => ({
    key: `${project.id}-${index}`,
    image: img.image,
    alt: img.alt,
    title,
    category,
    location,
    href: withBase(`/projects/${project.id}`),
  }));
});
---

<Layout
  title="Gallery"
  description="A visual index of AKAM Architects & Construction's work - every image links back to its project."
>
  <section class="container-page pb-10 pt-36 md:pt-44">
    {
      heading && (
        <Reveal client:visible>
          {eyebrow && <p class="text-xs uppercase tracking-[0.3em] text-accent">{eyebrow}</p>}
          <h1 class="mt-3 max-w-2xl text-balance font-heading text-4xl tracking-tight md:text-6xl">
            {heading}
          </h1>
          {intro && <p class="mt-5 max-w-lg leading-relaxed text-stone">{intro}</p>}
        </Reveal>
      )
    }
  </section>

  <section class="container-page pb-24">
    <div class="columns-1 gap-4 sm:columns-2 lg:columns-3">
      {
        galleryItems.map((item, index) => (
          <a
            href={item.href}
            class="group relative mb-4 block break-inside-avoid overflow-hidden bg-mist"
            aria-label={`${item.title} - ${item.category}, ${item.location}`}
          >
            <Image
              src={item.image}
              alt={item.alt}
              widths={[400, 700, 1000]}
              sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
              loading={index < 6 ? "eager" : "lazy"}
              class="w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
            />
            <div class="pointer-events-none absolute inset-0 flex flex-col justify-end bg-gradient-to-t from-ink/80 via-ink/0 to-ink/0 p-5 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
              <p class="font-heading text-base text-paper">{item.title}</p>
              <p class="text-xs uppercase tracking-[0.15em] text-paper/70">
                {item.category} - {item.location}
              </p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
